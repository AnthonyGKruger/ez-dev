# Copy to .env and fill in the values. `.env` is gitignored.

# --- Site ---
# Canonical site URL (SEO, sitemap, OG tags). Defaults to production URL if unset.
NUXT_PUBLIC_SITE_URL=https://www.ezdev.solutions

# --- Analytics ---
# Google Tag Manager container ID (GTM-XXXXXXX). Leave empty to disable.
NUXT_PUBLIC_GTM_ID=

# --- Contact form ---
# EmailJS public key (dashboard > Account > API keys). Used by the contact form.
NUXT_PUBLIC_EMAIL_JS_SECURE_TOKEN=
# Cloudflare Turnstile keys (dashboard > Turnstile). Site key is public,
# secret key is server-only (used by /api/turnstile-verify).
# For LOCAL dev use Cloudflare's test keys (real keys reject localhost and the
# widget retries forever): site 1x00000000000000000000AA,
# secret 1x0000000000000000000000000000000AA (always pass).
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Local dev ---
# Set to true to hide the Nuxt DevTools panel and the Nuxt Studio dev editor
# while working on UI (both re-open on refresh otherwise). Local only.
DEV_CLEAN_UI=

# --- Nuxt Studio (self-hosted editor at /_studio) ---
# Needed for editor login in PRODUCTION only — local `nuxt dev` needs no auth
# (edits sync straight to the files in content/**).
# Create a GitHub OAuth app at https://github.com/settings/developers:
#   Homepage URL:               https://www.ezdev.solutions
#   Authorization callback URL: https://www.ezdev.solutions/__nuxt_studio/auth/github
# Set these on the deployment platform (e.g. Vercel) as well.
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
# Optional: only if the auto-detected callback URL is wrong (e.g. behind a proxy).
# STUDIO_GITHUB_REDIRECT_URL=https://www.ezdev.solutions/__nuxt_studio/auth/github
